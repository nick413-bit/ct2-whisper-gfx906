# Copy to .env and fill in.
# Get a token at https://huggingface.co/settings/tokens and accept the
# pyannote/speaker-diarization-3.1 model license before use.
HF_TOKEN=

# Host directory that will be mounted at /models inside the container.
MODELS_DIR=/srv/models

# Optional overrides
MODEL_PATH=large-v3-turbo
MODEL_NAME=whisper
COMPUTE_TYPE=int8
BEAM_SIZE=2
PORT=8000
